<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:casefile.desktop.ViewModels.Clients.SubPages"
             xmlns:pageEmailHistory="clr-namespace:casefile.desktop.ViewModels.Clients.SubPages.PageEmailHistory"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="casefile.desktop.Views.Pages.Clients.SubPages.ShowClientHistoriqueEmailsSubPageView"
             x:DataType="pageEmailHistory:ShowClientHistoriqueEmailsSubPageViewModel">
    <Border>
        <TextBlock Text="Page Historique emails (a completer)" />
    </Border>
</UserControl>
